{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legacy Baseline Schema",
  "type": "object",
  "required": ["system", "migrationUnits", "endpoints", "views", "risks", "unknowns"],
  "properties": {
    "system": {
      "type": "object",
      "required": ["name", "legacyFramework", "targetFramework", "analysisStatus"],
      "properties": {
        "name": { "type": "string" },
        "legacyFramework": { "type": "string" },
        "targetFramework": { "type": "string" },
        "generatedAt": { "type": "string" },
        "analysisStatus": { "enum": ["PARTIAL", "COMPLETE", "BLOCKED"] }
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "properties": {
          "path": {
            "enum": [
              "00_MIGRATION_SCOPE.md",
              "01_LEGACY_INVENTORY.md",
              "02_LEGACY_BASELINE.md",
              "03_UNIT_TEST_SPEC_FROM_LEGACY_BASELINE.md",
              "04_COMPATIBILITY_DESIGN.md",
              "05_NEW_PROJECT_BASELINE.md",
              "06_NEW_PROJECT_TEST_SCAFFOLD.md",
              "07_ENDPOINT_VIEW_MIGRATION_TRACKER.md",
              "08_CONTRACT_REGRESSION_REPORT.md",
              "09_VIEW_UI_REGRESSION_REPORT.md",
              "10_MIGRATION_RISK_REGISTER.md",
              "11_ACCEPTANCE_CHECKLIST.md",
              "15_DEFERRED_ISSUES_REPORT.md",
              "legacy-baseline.json"
            ]
          },
          "status": { "enum": ["NOT_STARTED", "PARTIAL", "COMPLETE", "BLOCKED", "NOT_APPLICABLE"] },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "migrationUnits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "name", "status"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["endpoint", "view", "job", "integration", "business-flow", "other"] },
          "name": { "type": "string" },
          "status": {
            "enum": [
              "NOT_STARTED",
              "BASELINE_READY",
              "TEST_SPEC_READY",
              "BASE_PROJECT_READY",
              "CONVERTING",
              "REGRESSION_RUNNING",
              "PASS",
              "FAIL",
              "BLOCKED",
              "DEFERRED"
            ]
          },
          "acceptanceStatus": { "enum": ["PASS", "FAIL", "BLOCKED", "PARTIAL", "DEFERRED"] },
          "legacyBaselinePath": { "type": "string" },
          "testSpecPath": { "type": "string" },
          "regressionReportPath": { "type": "string" },
          "deferredIssues": { "type": "array", "items": { "type": "string" } },
          "blockingReason": { "type": "string" }
        }
      }
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "method", "legacyUrl", "verificationLevel", "analysisStatus", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "method": { "type": "string" },
          "legacyUrl": { "type": "string" },
          "controller": { "type": "string" },
          "action": { "type": "string" },
          "authRequired": { "type": "boolean" },
          "request": { "type": "object" },
          "response": {
            "type": "object",
            "properties": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "type", "source", "evidence"],
                  "properties": {
                    "path": { "type": "string" },
                    "type": { "type": "string" },
                    "required": { "type": "boolean" },
                    "nullable": { "type": "boolean" },
                    "source": { "type": "string" },
                    "branchCondition": { "type": "string" },
                    "evidence": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "unresolvedPaths": { "type": "array", "items": { "type": "string" } }
            }
          },
          "sideEffects": { "type": "object" },
          "verificationLevel": {
            "enum": ["DISCOVERED", "CODE_VERIFIED", "RUNTIME_VERIFIED", "TEST_VERIFIED", "UNKNOWN"]
          },
          "analysisStatus": { "enum": ["PARTIAL", "COMPLETE", "BLOCKED"] },
          "evidence": {
            "type": "object",
            "required": ["staticSources", "manualSourceTrace", "sequenceDiagram", "runtimeCaptures", "testAssets", "missingEvidence"],
            "properties": {
              "staticSources": { "type": "array", "items": { "type": "string" } },
              "manualSourceTrace": { "type": "array", "items": { "type": "string" } },
              "sequenceDiagram": { "type": "string" },
              "runtimeCaptures": { "type": "array", "items": { "type": "string" } },
              "testAssets": { "type": "array", "items": { "type": "string" } },
              "missingEvidence": { "type": "array", "items": { "type": "string" } }
            }
          },
          "sourceReferences": { "type": "array" },
          "migrationRisks": { "type": "array" }
        }
      }
    },
    "views": { "type": "array" },
    "risks": { "type": "array" },
    "unknowns": { "type": "array" }
  }
}
