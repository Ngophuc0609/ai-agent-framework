#!/usr/bin/env python3
"""
Generate native instruction files for common AI coding agents from .ai/.

Default target:
  current working directory
"""

from __future__ import annotations

import argparse
import hashlib
import json
from pathlib import Path
import subprocess


GENERATED_MARKER = "<!-- generated-by: ai-agent-adapter-sync -->"
GENERATOR_NAME = "ai-agent-adapter-sync"
GENERATOR_VERSION = "2.0"
FRAMEWORK_VERSION = "2"
MAX_POINTER_LINES = 250
MAX_POINTER_BYTES = 12000
MATERIALIZED_HEADING = "## Materialized .ai Rule Bundle"
DEFAULT_AGENTS = [
    "codex",
    "cursor",
    "copilot",
    "claude",
    "cline",
    "antigravity",
]

SUPPORTED_AGENTS = ["agents", *DEFAULT_AGENTS]

CORE_FILES = [
    ".ai/README.md",
    ".ai/BOOTSTRAP_ONCE.md",
    ".ai/registry/adapters.yml",
    ".ai/registry/skills.yml",
    ".ai/registry/workflows.yml",
    ".ai/registry/triggers.yml",
    ".ai/registry/tool-bootstrap.json",
    ".ai/registry/tool-candidates.json",
    ".ai/rules/00-global-rules.md",
    ".ai/rules/01-documentation-skill.md",
    ".ai/rules/02-multi-agent-rules.md",
    ".ai/rules/03-safety-rules.md",
    ".ai/rules/04-one-command-trigger.md",
    ".ai/rules/05-workflow-execution-rules.md",
    ".ai/rules/06-quality-gates.md",
    ".ai/rules/07-agent-review-rules.md",
    ".ai/rules/08-model-routing-rules.md",
    ".ai/rules/09-model-trigger-rules.md",
    ".ai/rules/10-codegraph-first-rules.md",
    ".ai/rules/11-skillflow-extension-rules.md",
    ".ai/rules/12-memory-policy-rules.md",
    ".ai/rules/13-efficiency-cost-policy-rules.md",
    ".ai/rules/14-tdd-first-feature-rules.md",
    ".ai/rules/15-agent-runtime-tool-policy.md",
    ".ai/rules/16-dotnet-parity-migration-rules.md",
]

ADAPTER_FILES = {
    "codex": [".ai/adapters/codex.md"],
    "cursor": [".ai/adapters/cursor.md"],
    "cline": [".ai/adapters/cline.md"],
    "claude": [".ai/adapters/claude.md"],
    "copilot": [".ai/adapters/copilot.md"],
    "antigravity": [".ai/adapters/antigravity.md"],
}

SKILL_TARGET_DIRS = {
    "agents": [".agents/skills"],
    "codex": [".agents/skills"],
    "cursor": [".agents/skills"],
    "copilot": [".github/skills"],
    "claude": [".claude/skills"],
    "cline": [".cline/skills"],
    "antigravity": [".agents/skills"],
}

MANIFEST_PATHS = {
    "agents": ".agents/00-ai-framework.manifest.json",
    "codex": ".agents/00-ai-framework.manifest.json",
    "cursor": ".cursor/rules/00-ai-framework.manifest.json",
    "copilot": ".github/instructions/00-ai-framework.manifest.json",
    "claude": ".claude/rules/00-ai-framework.manifest.json",
    "cline": ".clinerules/00-ai-framework.manifest.json",
    "antigravity": ".agent/rules/00-ai-framework.manifest.json",
}

POINTER_OBSOLETE_PATHS = {
    "cursor": [".cursor/rules/99-ai-framework-bundle.mdc"],
}


def resolve_path(value: str | Path) -> Path:
    return Path(value).expanduser().resolve()


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="replace").rstrip()


def existing_generated(path: Path) -> bool:
    if not path.exists() or not path.is_file():
        return False
    content = read_text(path)
    if GENERATED_MARKER in content:
        return True
    if path.name.endswith(".manifest.json"):
        try:
            manifest = json.loads(content)
        except json.JSONDecodeError:
            return False
        return manifest.get("generator", {}).get("name") == GENERATOR_NAME
    return False


def write_generated(path: Path, content: str, force: bool, dry_run: bool) -> str:
    if path.exists() and not force and not existing_generated(path):
        return f"SKIP existing user file: {path}"

    if dry_run:
        action = "overwrite" if path.exists() else "create"
        return f"DRY-RUN would {action}: {path}"

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content.rstrip() + "\n", encoding="utf-8")
    return f"WROTE {path}"


def available_files(repo: Path, paths: list[str]) -> list[str]:
    return [path for path in paths if (repo / path).is_file()]


def source_files(repo: Path, tool: str) -> list[str]:
    paths = CORE_FILES + ADAPTER_FILES.get(tool, []) + ["bin/ai-agent-adapter-sync"]
    return available_files(repo, paths)


def source_bundle(repo: Path, tool: str) -> str:
    files = source_files(repo, tool)
    sections = []
    for rel_path in files:
        path = repo / rel_path
        sections.append(
            "\n".join(
                [
                    "",
                    f"## Source File: `{rel_path}`",
                    "",
                    f"<!-- BEGIN SOURCE: {rel_path} -->",
                    read_text(path),
                    f"<!-- END SOURCE: {rel_path} -->",
                    "",
                ]
            )
        )
    return "\n".join(sections).strip()


def compact_header(tool: str) -> str:
    return "\n".join(
        [
            GENERATED_MARKER,
            f"# .ai Framework Instructions for {tool}",
            "",
            "Source of truth: `.ai/`",
            "Mode: pointer-only; do not treat this generated file as a policy copy.",
            "",
            "## Progressive Startup",
            "",
            "Before any coding, documentation, debugging, review, refactor, commit, or analysis task:",
            "",
            "1. Verify `.ai/` exists in this repository.",
            "2. Read `.ai/README.md`, `.ai/rules/00-global-rules.md`, and `.ai/rules/15-agent-runtime-tool-policy.md`.",
            "3. Inspect runtime state using safe local checks. Do not install tools or packages automatically.",
            f"4. Read `.ai/adapters/{tool}.md` when native tool constraints are relevant and the file exists.",
            "5. Read `.ai/registry/triggers.yml` and match the user intent.",
            "6. Read only the selected `SKILL.md`, selected workflow, and their directly referenced rules.",
            "7. Execute with bounded source scope and validate only applicable quality gates.",
            "8. Record tool fallbacks, confidence/readiness impact, and evidence paths.",
            "",
            "The one-time bootstrap document is setup-only. Do not load it during normal tasks.",
            "",
            "## Non-Negotiable Rules",
            "",
            "- `.ai/` is canonical; this file only points to current policy.",
            "- Keep filesystem access within the active repository.",
            "- Never expose secrets or store unverified/raw source in memory.",
            "- Package/tool installation and other high-risk actions require runtime-appropriate approval.",
            "- Current source and executable evidence override memory and generated documentation.",
            "- New backend features/APIs/jobs/webhooks/integrations require brainstorm, contract, acceptance criteria, and tests before production code.",
            "- Respond to the Vietnamese-speaking user in Vietnamese unless another language is requested.",
            "",
            "## Rule Loading Matrix",
            "",
            "- Every task: `00-global-rules.md`, `03-safety-rules.md`, `15-agent-runtime-tool-policy.md`.",
            "- Skill/workflow routing: `triggers.yml`, then only the selected skill and workflow. Read `skills.yml` or `workflows.yml` only when metadata resolution requires them.",
            "- Localized source work: apply `10-codegraph-first-rules.md` and `12-memory-policy-rules.md` as preferred, non-blocking preflight with documented fallback.",
            "- Architecture, source handover, cross-module analysis, broad refactor, dependency tracing: attempt CodeGraph first; block only when the selected workflow requires graph evidence.",
            "- New backend behavior: `14-tdd-first-feature-rules.md` and `developing-backend-feature-tdd`.",
            "- Source handover: load its selected skill/workflow and required agent/evidence rules exactly.",
            "- Model routing: load `08-model-routing-rules.md` and `09-model-trigger-rules.md` only for model selection/routing tasks.",
            "",
            "## Runtime Fallbacks",
            "",
            "- Missing Memory: use `docs/PROJECT_CONTEXT.md`, `docs/FINDINGS.md`, and `docs/DECISIONS.md`; record the limitation and do not claim a memory write.",
            "- Missing CodeGraph on localized work: use `rg`, IDE/LSP references, and narrow source slices; downgrade confidence/readiness.",
            "- Missing required workflow evidence: stop that workflow rather than fabricate output.",
            "",
            "## Completion Contract",
            "",
            "Before completion, report changed files, validations run, fallbacks/limitations, and readiness. Run `ai-agent-adapter-sync --check` when framework or adapter sources changed.",
        ]
    )


def full_bundle(tool: str, repo: Path) -> str:
    return "\n\n".join(
        [
            compact_header(tool),
            MATERIALIZED_HEADING,
            "",
            "This section is generated from `.ai/` so native agent rule systems can load the framework without a manual bootstrap prompt.",
            source_bundle(repo, tool),
        ]
    )


def validate_pointer_content(content: str) -> None:
    line_count = len(content.splitlines())
    byte_count = len(content.encode("utf-8"))
    if line_count > MAX_POINTER_LINES:
        raise ValueError(f"Pointer adapter exceeds {MAX_POINTER_LINES} lines: {line_count}")
    if byte_count > MAX_POINTER_BYTES:
        raise ValueError(f"Pointer adapter exceeds {MAX_POINTER_BYTES} bytes: {byte_count}")
    if MATERIALIZED_HEADING in content:
        raise ValueError("Pointer adapter contains the forbidden materialized bundle heading")


def source_commit(repo: Path) -> str | None:
    completed = subprocess.run(
        ["git", "-C", str(repo), "rev-parse", "HEAD"],
        check=False,
        capture_output=True,
        text=True,
    )
    return completed.stdout.strip() if completed.returncode == 0 else None


def manifest_content(repo: Path, agent: str, materialized: bool) -> str:
    sources = []
    for relative_path in source_files(repo, agent):
        digest = hashlib.sha256((repo / relative_path).read_bytes()).hexdigest()
        sources.append({"path": relative_path, "sha256": digest})
    manifest = {
        "schema_version": 1,
        "agent": agent,
        "mode": "materialized" if materialized else "pointer",
        "generator": {"name": GENERATOR_NAME, "version": GENERATOR_VERSION},
        "framework_version": FRAMEWORK_VERSION,
        "source_commit": source_commit(repo),
        "sources": sources,
    }
    return json.dumps(manifest, indent=2, sort_keys=True)


def insert_marker_after_frontmatter(content: str) -> str:
    lines = content.rstrip().splitlines()
    if lines and lines[0].strip() == "---":
        for index in range(1, len(lines)):
            if lines[index].strip() == "---":
                next_index = index + 1
                return "\n".join(
                    lines[:next_index]
                    + ["", GENERATED_MARKER, ""]
                    + lines[next_index:]
                )
    return "\n".join([GENERATED_MARKER, "", content.rstrip()])


def source_skill_dirs(repo: Path) -> list[Path]:
    skills_dir = repo / ".ai" / "skills"
    if not skills_dir.is_dir():
        return []
    return sorted(path.parent for path in skills_dir.glob("*/SKILL.md"))


def target_skill_files(repo: Path, agent: str) -> list[tuple[Path, str]]:
    targets: list[tuple[Path, str]] = []
    target_dirs = SKILL_TARGET_DIRS.get(agent, [])
    for skill_dir in source_skill_dirs(repo):
        source_skill = skill_dir / "SKILL.md"
        content = insert_marker_after_frontmatter(read_text(source_skill))
        for target_dir in target_dirs:
            targets.append((repo / target_dir / skill_dir.name / "SKILL.md", content))
    return targets


def cursor_mdc(title: str, body: str, always: bool) -> str:
    metadata = (
        ["---", "alwaysApply: true", "---"]
        if always
        else ["---", f"description: {title}", "alwaysApply: false", "---"]
    )
    return "\n".join(
        metadata + ["", body]
    )


def claude_rule(body: str) -> str:
    return "\n".join(
        [
            "---",
            "paths:",
            '  - ".ai/**/*"',
            '  - "bin/ai-agent-*"',
            "---",
            "",
            body,
        ]
    )


def copilot_instruction(body: str, apply_to: str) -> str:
    return "\n".join(
        [
            "---",
            f'applyTo: "{apply_to}"',
            "---",
            "",
            body,
        ]
    )


def target_files(repo: Path, agent: str, materialized: bool) -> list[tuple[Path, str]]:
    compact = compact_header(agent)
    bundle = full_bundle(agent, repo)
    deep_content = bundle if materialized else compact
    targets: dict[str, list[tuple[str, str]]] = {
        "agents": [
            ("AGENTS.md", compact),
        ],
        "codex": [
            ("AGENTS.md", compact),
        ],
        "cursor": [
            (".cursor/rules/00-ai-framework.mdc", cursor_mdc("Always apply .ai framework routing and startup rules", compact, True)),
        ],
        "copilot": [
            (".github/copilot-instructions.md", compact),
            (
                ".github/instructions/ai-framework.instructions.md",
                copilot_instruction(deep_content, ".ai/**,bin/ai-agent-*"),
            ),
        ],
        "claude": [
            ("CLAUDE.md", compact),
            (".claude/rules/00-ai-framework.md", claude_rule(deep_content)),
        ],
        "cline": [
            (".clinerules/00-ai-framework.md", deep_content),
        ],
        "antigravity": [
            ("GEMINI.md", compact),
            (".agent/rules/00-ai-framework.md", deep_content),
            (".agents/AGENTS.md", compact),
        ],
    }
    if agent == "cursor" and materialized:
        targets[agent].append(
            (
                ".cursor/rules/99-ai-framework-bundle.mdc",
                cursor_mdc("Full .ai framework bundle for deep framework, registry, and rule work", bundle, False),
            )
        )
    resolved = [(repo / path, content) for path, content in targets[agent]]
    if not materialized:
        for _, content in resolved:
            validate_pointer_content(content)
    resolved.append(
        (repo / MANIFEST_PATHS[agent], manifest_content(repo, agent, materialized))
    )
    return resolved


def remove_obsolete_pointer_files(repo: Path, agent: str, dry_run: bool) -> list[str]:
    results = []
    for relative_path in POINTER_OBSOLETE_PATHS.get(agent, []):
        path = repo / relative_path
        if not path.exists() or not existing_generated(path):
            continue
        if dry_run:
            results.append(f"DRY-RUN would remove generated legacy file: {path}")
        else:
            path.unlink()
            results.append(f"REMOVED generated legacy file: {path}")
    return results


def check_generated(path: Path, expected: str) -> str | None:
    if not path.is_file():
        return f"DRIFT missing: {path}"
    actual = path.read_text(encoding="utf-8", errors="replace").rstrip()
    if actual != expected.rstrip():
        return f"DRIFT content: {path}"
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Generate native AI-agent instruction files from .ai/.",
    )
    parser.add_argument(
        "repo",
        nargs="?",
        default=".",
        help="Target repository path. Defaults to the current directory.",
    )
    parser.add_argument(
        "--agent",
        action="append",
        choices=sorted(SUPPORTED_AGENTS),
        help="Generate one adapter target. Can be repeated. Defaults to all.",
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing files even when they were not generated by this script.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print target files without writing.",
    )
    parser.add_argument(
        "--no-skills",
        action="store_true",
        help="Only generate native rule/instruction files; skip native Agent Skills.",
    )
    parser.add_argument(
        "--materialized",
        action="store_true",
        help="Embed the full .ai source bundle for restricted runtimes. Pointer-only is the default.",
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="Report generated output or source-manifest drift without writing files.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    repo = resolve_path(args.repo)
    ai_dir = repo / ".ai"
    if not repo.is_dir():
        print(f"Target repository does not exist: {repo}")
        return 2
    if not ai_dir.is_dir():
        print(f"Missing .ai directory: {ai_dir}")
        return 2

    agents = args.agent or DEFAULT_AGENTS
    exit_code = 0
    written_paths: set[Path] = set()

    for agent in agents:
        print(f"Agent adapter: {agent}")
        generated_targets = target_files(repo, agent, args.materialized)
        if not args.no_skills:
            generated_targets.extend(target_skill_files(repo, agent))

        if not args.materialized:
            for relative_path in POINTER_OBSOLETE_PATHS.get(agent, []):
                obsolete = repo / relative_path
                if not obsolete.exists():
                    continue
                if args.check and existing_generated(obsolete):
                    print(f"- DRIFT obsolete generated file: {obsolete}")
                    exit_code = 1
                elif not existing_generated(obsolete):
                    print(f"- SKIP obsolete user file: {obsolete}")
                    exit_code = 1
            if not args.check:
                for result in remove_obsolete_pointer_files(repo, agent, args.dry_run):
                    print(f"- {result}")

        for path, content in generated_targets:
            if path in written_paths:
                print(f"- SKIP duplicate target already handled: {path}")
                continue
            if args.check:
                drift = check_generated(path, content)
                if drift:
                    print(f"- {drift}")
                    exit_code = 1
                else:
                    print(f"- OK {path}")
                written_paths.add(path)
                continue
            result = write_generated(path, content, args.force, args.dry_run)
            print(f"- {result}")
            written_paths.add(path)
            if result.startswith("SKIP"):
                exit_code = 1
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
